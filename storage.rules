rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Incheckningsbilder — userId i sökvägen enforcar ägarskap
    match /images/checkins/{userId}/{checkinId}/{fileName} {
      allow read;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 15 * 1024 * 1024;
    }

    // Lekplatsbilder — bara admins kan ladda upp
    match /images/playgrounds/{playgroundId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Profilbilder — bara ägaren kan skriva
    match /profilbilder/{userId} {
      allow read;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Trofé-bilder — statiska, laddas upp manuellt via konsolen
    match /trofeer/{imageName} {
      allow read;
    }

  }
}
