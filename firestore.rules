rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /lekplatser/{lekplatsId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bildUrl'])
         && request.resource.data.bildUrl.startsWith('https://firebasestorage.googleapis.com/v0/b/' + request.auth.token.firebase.project_id))
      );
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /incheckningar/{checkinId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      // Tillåt bara att lägga till/ta bort EGET UID i likes-arrayen
      allow update: if request.auth != null && (
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
          && (
            // Lägger till sin egen like
            (request.resource.data.likes == resource.data.likes + [request.auth.uid]
             && request.resource.data.likes.size() == resource.data.likes.size() + 1)
            ||
            // Tar bort sin egen like
            (resource.data.likes == request.resource.data.likes + [request.auth.uid]
             && request.resource.data.likes.size() == resource.data.likes.size() - 1)
          )
        )
        || (request.auth.uid == resource.data.userId
              && request.resource.data.diff(resource.data)
                  .affectedKeys().hasOnly(['bildUrl']))
        // Ägaren kan redigera sin incheckning (lekplatsId och userId är låsta)
        || (request.auth.uid == resource.data.userId
              && request.resource.data.userId == resource.data.userId
              && request.resource.data.lekplatsId == resource.data.lekplatsId
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['betyg', 'kommentar', 'bildUrl', 'gjordaAktiviteter',
                            'klaradeUtmaningar', 'taggadeVanner', 'tidPaLekplats',
                            'redigerad', 'redigeradAt']))
      );

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                      && resource.data.userId == request.auth.uid;
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Användaren kan bara uppdatera sitt eget dokument med tillåtna fält.
      // Friends-arrayen hanteras via Cloud Functions (friendRequests-flödet).
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'fornamn', 'efternamn', 'smeknamn', 'smeknamnLower', 'profilbildUrl',
              'friends', 'totalCheckinCount', 'visitedPlaygroundIds',
              'trophyProgress', 'favorites', 'expoPushToken'
            ]);
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /completedChallenges/{lekplatsId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /klaradeUtmaningar/{lekplatsId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }

      match /unlockedTrophies/{trophyId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if false;
      }

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
        // Admins kan skicka notiser till vilken användare som helst
        allow create: if request.auth != null && (
          request.auth.uid == userId ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        );
      }
    }

    match /sponsors/{sponsorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;

      match /stats/{date} {
        // Alla inloggade kan logga analytikshändelser
        allow write: if request.auth != null;
        // Bara admins kan läsa statistik
        allow read: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      }
    }

    match /trophies/{trophyId} {
      allow read: if true;
      allow write: if false;
    }

    match /konfiguration/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /andringsforslag/{forslagId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /friendRequests/{requestId} {
      allow read: if request.auth != null &&
        (resource.data.fromUserId == request.auth.uid ||
         resource.data.toUserId == request.auth.uid);
      allow create: if request.auth != null &&
        request.resource.data.fromUserId == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.toUserId == request.auth.uid;
      allow delete: if request.auth != null &&
        (resource.data.fromUserId == request.auth.uid ||
         resource.data.toUserId == request.auth.uid);
    }

    match /nyheter/{newsId} {
      allow read: if resource.data.publicerad == true
        || (request.auth != null &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /rapporter/{rapportId} {
      // Inloggade användare kan skapa rapporter om sitt eget UID
      allow create: if request.auth != null
                    && request.resource.data.reportedByUserId == request.auth.uid;
      // Ingen annan klientaccess – bara admins via Cloud Functions eller admin-SDK
      allow read, update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      allow delete: if false;
    }

    // Intern samling för idempotens i Cloud Functions — ingen klientaccess
    match /_processedEvents/{eventId} {
      allow read, write: if false;
    }

  }
}
